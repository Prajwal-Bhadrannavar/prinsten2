# Google Maps API Configuration
# =============================
# 
# HOW TO SET UP:
# 1. Go to https://cloud.google.com/console
# 2. Create a new project
# 3. Enable the following APIs:
#    - Maps JavaScript API
#    - Geocoding API
#    - Places API
# 4. Create an API key (Credentials > API key)
# 5. Restrict the key to:
#    - Application restrictions: HTTP referrers
#    - Add: localhost:3000 and your production domain
# 6. Replace YOUR_GOOGLE_MAPS_API_KEY below with your actual key
#
REACT_APP_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Backend API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Environment
REACT_APP_ENV=development
